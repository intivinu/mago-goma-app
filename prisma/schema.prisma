// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Word {
  id      Int    @id @default(autoincrement())
  text    String @unique
  isValid Boolean @default(true)
  level   Int    @default(1)
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  score     Int      @default(0)
  pvpWins   Int      @default(0)
  pvpLosses Int      @default(0)
  rankScore Int      @default(1000)
  createdAt DateTime @default(now())
  sessions  GameSession[]
  suggestions SuggestedWord[]
  matchesAsP1 Match[] @relation("Player1")
  matchesAsP2 Match[] @relation("Player2")
}

model GameSession {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  score     Int      @default(0)
  difficulty String   @default("aprendiz")
  wordsPlayed String // JSON stringified array of words
  createdAt DateTime @default(now())
}

model SuggestedWord {
  id        Int      @id @default(autoincrement())
  text      String
  status    String   @default("pending") // pending, approved, rejected
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Match {
  id            String   @id @default(uuid())
  player1Id     Int
  player2Id     Int?
  player1       User     @relation("Player1", fields: [player1Id], references: [id])
  player2       User?    @relation("Player2", fields: [player2Id], references: [id])
  status        String   @default("waiting") // waiting, playing, finished, abandoned
  currentTurnId Int?
  winnerId      Int?
  wordsPlayed   String   @default("[]") // JSON string array
  lastWord      String?
  lastMoveAt    DateTime @default(now())
  createdAt     DateTime @default(now())
}
